{
  "name": "mcprobe",
  "version": "0.1.0",
  "description": "MCProbe audits MCP servers over the live protocol by linting tool schemas and behaviorally fuzzing them with broken inputs.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "mcprobe": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "claude.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p examples/demo-target/tsconfig.json",
    "build:probe": "tsc -p tsconfig.json",
    "build:demo": "tsc -p examples/demo-target/tsconfig.json",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
